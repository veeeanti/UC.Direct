{
  "name": "unioncrax-direct",
  "version": "1.8.5-BETA",
  "description": "Standalone Electron app for managing and launching games from UnionCrax",
  "type": "module",
  "main": "electron/main.cjs",
  "author": "UnionCrax",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Union-Crax/UnionCrax.Direct.git"
  },
  "bugs": {
    "url": "https://github.com/Union-Crax/UnionCrax.Direct/issues"
  },
  "homepage": "https://github.com/Union-Crax/UnionCrax.Direct#readme",
  "scripts": {
    "setup": "node ./node_modules/electron/install.js",
    "dev": "concurrently -k \"pnpm:dev:renderer\" \"pnpm:dev:electron\"",
    "dev:renderer": "vite --config renderer/vite.config.ts",
    "dev:electron": "wait-on http://localhost:5173 && node ./scripts/run-electron.cjs ./electron/main.cjs",
    "build": "pnpm -s build:renderer && pnpm -s build:electron",
    "build:renderer": "vite build --config renderer/vite.config.ts",
    "build:electron": "node ./scripts/build-electron.cjs",
    "fetch-gcpad": "node ./scripts/fetch-gcpad.cjs",
    "pack": "pnpm -s fetch-gcpad && pnpm -s build && electron-builder",
    "rebuild-native": "cd electron/native && node-gyp rebuild",
    "postinstall": "pnpm rebuild-native || echo 'Native overlay addon build skipped (install C++ build tools to enable)'"
  },
  "dependencies": {
    "7zip-bin": "^5.0.0",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "1.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "1.1.4",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-scroll-area": "1.2.2",
    "@radix-ui/react-select": "2.1.4",
    "@radix-ui/react-separator": "1.1.1",
    "@radix-ui/react-slider": "1.2.2",
    "@radix-ui/react-slot": "1.1.1",
    "@radix-ui/react-switch": "1.1.2",
    "@radix-ui/react-tabs": "1.1.2",
    "@radix-ui/react-tooltip": "1.1.6",
    "class-variance-authority": "^0.7.1",
    "classic-level": "^3.0.0",
    "clsx": "^2.1.1",
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.8.3",
    "embla-carousel-react": "^8.5.1",
    "fuse.js": "^7.1.0",
    "geist": "^1.5.1",
    "lucide-react": "^0.454.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.9",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "node-addon-api": "^7.1.0",
    "node-gyp": "^10.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.9",
    "tw-animate-css": "1.3.3",
    "typescript": "^5.9.2",
    "vite": "^6.4.1",
    "wait-on": "^8.0.5"
  },
  "build": {
    "icon": "assets/icon.ico",
    "appId": "xyz.unioncrax.direct",
    "productName": "UnionCrax.Direct",
    "npmRebuild": false,
    "publish": [
      {
        "provider": "github",
        "owner": "Union-Crax",
        "repo": "UnionCrax.Direct"
      }
    ],
    "directories": {
      "output": "dist-packaged",
      "buildResources": "assets"
    },
    "files": [
      "assets/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "renderer/dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/7zip-bin",
      "electron/native/build/**/*"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis",
        "portable",
        "zip"
      ],
      "extraResources": [
        {
          "from": "build/Release/uc-overlay-x64.dll",
          "to": "uc-overlay-x64.dll"
        },
        {
          "from": "gcpad-dll/gcpad.dll",
          "to": "gcpad.dll"
        },
        {
          "from": "gcpad-dll/SDL2.dll",
          "to": "SDL2.dll"
        }
      ]
    },
    "nsis": {
      "artifactName": "${productName}.Setup.${version}.${ext}",
      "oneClick": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "UnionCrax.Direct"
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "icon": "assets/icons"
    }
  },
  "pnpm": {
    "overrides": {
      "react-server-dom-webpack": "19.2.3",
      "react-server-dom-parcel": "19.2.3",
      "react-server-dom-turbopack": "19.2.3"
    }
  }
}
